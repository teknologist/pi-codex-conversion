{
  "name": "@teknologist/pi-codex-conversion",
  "version": "1.1.0",
  "description": "Codex-oriented tool and prompt adapter for pi coding agent",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IgorWarzocha/pi-codex-conversion.git"
  },
  "homepage": "https://github.com/IgorWarzocha/pi-codex-conversion#readme",
  "bugs": {
    "url": "https://github.com/IgorWarzocha/pi-codex-conversion/issues"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "extension",
    "codex",
    "adapter",
    "apply-patch"
  ],
  "license": "MIT",
  "os": [
    "darwin",
    "linux"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ],
    "themes": [
      "./themes"
    ]
  },
  "files": [
    "src/**/*.ts",
    "src/**/*.md",
    "themes/**/*.json",
    "available-tools.png",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json",
    "test": "tsx --test tests/**/*.test.ts",
    "check": "npm run typecheck && npm run test",
    "publish:dry-run": "npm publish --dry-run",
    "publish:dev": "npm publish --tag dev",
    "release:dev": "npm version prerelease --preid dev && npm publish --tag dev",
    "prepack": "npm run check",
    "prepublishOnly": "npm run check"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@earendil-works/pi-tui": "^0.74.0",
    "typebox": "^1.1.37"
  },
  "devDependencies": {
    "tsx": "^4.20.5",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "node-pty": "^1.1.0",
    "tree-sitter-bash": "^0.25.1",
    "web-tree-sitter": "^0.26.7"
  }
}
